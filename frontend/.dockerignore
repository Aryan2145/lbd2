# Dependencies — reinstalled inside the image
node_modules

# Next.js build output — rebuilt inside the image
.next

# Git
.git
.gitignore

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Dev / editor noise
*.md
.DS_Store
*.log
.vscode
.idea

# Docker files themselves (no recursive copy)
Dockerfile
docker-compose.yml
